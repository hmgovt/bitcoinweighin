# Cloudflare Pages custom headers.
# https://developers.cloudflare.com/pages/configuration/headers/
#
# The dataset endpoints are intentionally CORS-open so that any browser-
# based notebook, dashboard, or research tool can fetch them without a
# proxy. Cache windows are short enough that a daily cron update is
# visible within minutes, long enough that a viral citation does not
# saturate the origin.

/api/prices.json
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, HEAD, OPTIONS
  Cache-Control: public, max-age=300
  X-Content-Type-Options: nosniff

/data/*
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, HEAD, OPTIONS
  Cache-Control: public, max-age=3600
  X-Content-Type-Options: nosniff

# SvelteKit's hashed bundles — content-addressed, safe to cache forever.
/_app/immutable/*
  Cache-Control: public, max-age=31536000, immutable

# Sprite art is large and effectively static. One-week TTL with
# stale-while-revalidate lets repeat visits skip the network entirely
# while still picking up re-renders within a reasonable window.
/sprites/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# Header art + favicon — same rationale, smaller payload.
/header.webp
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/header.jpg
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/favicon.png
  Cache-Control: public, max-age=604800

# prices.json is regenerated daily by the cron — short TTL, but allow
# CDN to serve while revalidating so a cache miss never blocks render.
/prices.json
  Cache-Control: public, max-age=300, stale-while-revalidate=3600
