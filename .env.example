# Copy to .env and fill in. .env is gitignored — never commit real keys.
# In production these are GitHub repo secrets (Settings → Secrets and variables → Actions).

# ── Price / data pipeline (daily-update.yml) ──────────────────────
FRED_API_KEY=
STOOQ_API_KEY=
MASSIVE_API_KEY=

# ── X (Twitter) bot (bot.yml) — OAuth 1.0a user context ───────────
# Mapping from the X developer portal's names:
#   X_API_KEY      → "API Key"        (a.k.a. Consumer Key)
#   X_API_SECRET   → "API Key Secret" (a.k.a. Consumer Secret)
#   X_ACCESS_TOKEN → "Access Token"
#   X_ACCESS_SECRET→ "Access Token Secret"
# Generate Access Token & Secret AFTER setting App permissions to Read+Write,
# or they stay read-only and posting 403s. No Bearer Token needed (read-only).
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
